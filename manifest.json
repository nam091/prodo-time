{
  "manifest_version": 3,
  "name": "ProdoTime - Productivity Timer",
  "version": "1.0.0",
  "description": "Beautiful productivity timer with stopwatch, countdown, sentences/sec calculator, Pomodoro mode & session history.",
  "permissions": ["storage", "alarms", "notifications"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
